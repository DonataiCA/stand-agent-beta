# Stand Agent — Root environment (used by docker-compose.yml)
# Copy this file to .env and fill in the values

# Anthropic API (OpenClaw LLM)
ANTHROPIC_API_KEY=your_anthropic_api_key

# Telegram Bot token (from @BotFather)
TELEGRAM_BOT_TOKEN=your_telegram_bot_token

# API Secret Key (same as backend API_SECRET_KEY — OpenClaw uses this to call the backend)
API_SECRET_KEY=your_api_secret_key_here

# Active Event UUID (set this to the current event's ID before starting OpenClaw)
ACTIVE_EVENT_ID=your_event_uuid_here
